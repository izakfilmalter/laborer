{
  "name": "laborer",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "effect": "3.19.12",
      "@effect/cli": "0.72.1",
      "@effect/cluster": "0.55.0",
      "@effect/experimental": "0.57.11",
      "@effect/opentelemetry": "0.59.3",
      "@effect/platform": "0.93.8",
      "@effect/platform-browser": "0.73.0",
      "@effect/platform-node": "0.103.0",
      "@effect/printer": "0.47.0",
      "@effect/printer-ansi": "0.47.0",
      "@effect/rpc": "0.72.2",
      "@effect/sql": "0.48.6",
      "@effect/typeclass": "0.38.0",
      "@effect/vitest": "0.27.0",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev dev:electron",
    "dev:web": "turbo dev --filter=!@laborer/desktop",
    "build": "turbo build",
    "typecheck": "turbo typecheck --ui=stream",
    "dev:native": "turbo -F native dev",
    "build:app": "turbo -F web build",
    "test": "turbo test --ui=stream --concurrency=3",
    "test:watch": "turbo test:watch --ui=stream --concurrency=3",
    "check": "turbo run //#format:fix typecheck test --ui=stream --concurrency=3",
    "dist:desktop:dmg": "tsx scripts/build-desktop-artifact.ts",
    "dist:desktop:artifact": "tsx scripts/build-desktop-artifact.ts",
    "format": "ultracite check",
    "format:fix": "ultracite fix",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@laborer/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@effect/language-service": "^0.77.0",
    "@laborer/config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.4",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "packageManager": "bun@1.3.5",
  "overrides": {
    "effect": "3.19.12",
    "@effect/cli": "0.72.1",
    "@effect/cluster": "0.55.0",
    "@effect/experimental": "0.57.11",
    "@effect/opentelemetry": "0.59.3",
    "@effect/platform": "0.93.8",
    "@effect/platform-browser": "0.73.0",
    "@effect/platform-node": "0.103.0",
    "@effect/printer": "0.47.0",
    "@effect/printer-ansi": "0.47.0",
    "@effect/rpc": "0.72.2",
    "@effect/sql": "0.48.6",
    "@effect/typeclass": "0.38.0"
  }
}
