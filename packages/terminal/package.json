{
  "name": "@laborer/terminal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "with-env": "dotenv -e ../../.env.local --",
    "dev": "bun run with-env bun run --watch src/main.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "bun run with-env bun run src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./src/main.ts"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/rpc": "catalog:",
    "@laborer/env": "workspace:*",
    "@laborer/shared": "workspace:*",
    "effect": "catalog:",
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@laborer/config": "workspace:*",
    "@types/bun": "^1.2.14",
    "@types/node": "^25.3.3",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
