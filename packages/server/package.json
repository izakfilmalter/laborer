{
  "name": "@laborer/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "with-env": "dotenv -e ../../.env.local --",
    "dev": "bun run with-env bun run --watch src/main.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "bun run with-env bun run src/main.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "exports": {
    ".": "./src/main.ts"
  },
  "dependencies": {
    "@effect/cluster": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/rpc": "catalog:",
    "@effect/sql": "catalog:",
    "@laborer/env": "workspace:*",
    "@laborer/shared": "workspace:*",
    "@livestore/adapter-node": "0.4.0-dev.22",
    "@livestore/livestore": "0.4.0-dev.22",
    "@livestore/sync-cf": "0.4.0-dev.22",
    "@parcel/watcher": "^2.5.6",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "@laborer/config": "workspace:*",
    "@types/bun": "^1.2.14",
    "@types/node": "^25.3.3",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
