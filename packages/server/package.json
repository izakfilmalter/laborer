{
  "name": "@laborer/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "with-env": "dotenv -e ../../.env.local --",
    "dev": "bun run with-env tsx --watch src/main.ts",
    "build": "tsdown && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "bun run with-env tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./src/main.ts"
  },
  "dependencies": {
    "@effect/cli": "catalog:",
    "@effect/cluster": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/opentelemetry": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/printer": "catalog:",
    "@effect/printer-ansi": "catalog:",
    "@effect/rpc": "catalog:",
    "@effect/sql": "catalog:",
    "@effect/typeclass": "catalog:",
    "@effect/workflow": "catalog:",
    "@laborer/env": "workspace:*",
    "@laborer/shared": "workspace:*",
    "@livestore/adapter-node": "0.4.0-dev.22",
    "@livestore/livestore": "0.4.0-dev.22",
    "@livestore/sync-cf": "0.4.0-dev.22",
    "@opentelemetry/api": "^1.9",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-logs": ">=0.203.0 <0.300.0",
    "@opentelemetry/sdk-metrics": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/sdk-trace-node": "^2.0.0",
    "@opentelemetry/sdk-trace-web": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.33.0",
    "better-sqlite3": "^12.6.2",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "@laborer/config": "workspace:*",
    "@laborer/file-watcher": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "tsdown": "^0.20.3",
    "tsx": "^4.19.4",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
